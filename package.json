{
  "name": "arsu-mobile-app-backend",
  "version": "1.0.0",
  "description": "ARSU Mobile App — Node.js / Express / Prisma / Supabase backend",
  "author": "ARSU Team",
  "license": "UNLICENSED",
  "private": true,
  "main": "dist/server.js",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arsu2026/arsu-mobile-app-backend.git"
  },
  "bugs": {
    "url": "https://github.com/arsu2026/arsu-mobile-app-backend/issues"
  },
  "homepage": "https://github.com/arsu2026/arsu-mobile-app-backend#readme",
  "scripts": {
    "prebuild": "npx prisma generate",
    "build": "tsc -p tsconfig.build.json",
    "dev": "dotenv -e .env.local -- ts-node-dev --respawn --transpile-only --exit-child src/server.ts",
    "dev:debug": "dotenv -e .env.local -- ts-node-dev --respawn --transpile-only --inspect src/server.ts",
    "start": "node --max-old-space-size=512 dist/server.js",
    "start:prod": "NODE_ENV=production node --max-old-space-size=512 dist/server.js",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "prisma:generate": "dotenv -e .env.local -- prisma generate",
    "prisma:studio": "dotenv -e .env.local -- prisma studio",
    "migration:generate:local": "dotenv -e .env.local -- prisma migrate dev",
    "migration:run:local": "dotenv -e .env.local -- prisma migrate deploy",
    "migration:run": "prisma migrate deploy",
    "migration:revert:local": "dotenv -e .env.local -- prisma migrate reset --force",
    "db:seed": "dotenv -e .env.local -- ts-node src/prisma/seed.ts",
    "postinstall": "npx prisma generate"
  },
  "keywords": [
    "nodejs",
    "express",
    "prisma",
    "supabase",
    "postgresql",
    "typescript"
  ],
  "dependencies": {
    "@prisma/client": "^6.17.1",
    "@supabase/supabase-js": "^2.108.1",
    "axios": "^1.17.0",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.19.0",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.11.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.11",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.2",
    "@types/nodemailer": "^8.0.0",
    "@types/passport": "^1.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "concurrently": "^10.0.3",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.4",
    "prisma": "^6.17.1",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3"
  }
}
